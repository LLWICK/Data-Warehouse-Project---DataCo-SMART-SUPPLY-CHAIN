              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[dbo].[stg_orders]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    -- Create Date_Key as INT (YYYYMMDD)
    CAST(FORMAT(TRY_CAST([order_date] AS DATETIME), 'yyyyMMdd') AS INT) AS Date_Key,
    
    -- Full Date object
    CAST(TRY_CAST([order_date] AS DATETIME) AS DATE) AS Full_Date,
    
    -- Numeric Day of Week (1-7)
    DATEPART(WEEKDAY, TRY_CAST([order_date] AS DATETIME)) AS Day_Of_Week,
    
    -- Name of Day (e.g. Monday)
    DATENAME(WEEKDAY, TRY_CAST([order_date] AS DATETIME)) AS Day_Name,
    
    -- Numeric Month (1-12)
    MONTH(TRY_CAST([order_date] AS DATETIME)) AS Month_Int,
    
    -- Name of Month (e.g. January)
    DATENAME(MONTH, TRY_CAST([order_date] AS DATETIME)) AS Month_Name,
    
    -- Quarter (1-4)
    DATEPART(QUARTER, TRY_CAST([order_date]AS DATETIME)) AS Quarter,
    
    -- Year (e.g. 2018)
    YEAR(TRY_CAST([order_date] AS DATETIME)) AS Year_Int
FROM stg_orders
WHERE [order_date] IS NOT NULL;</property>
